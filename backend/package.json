{
  "name": "book-composer-backend",
  "version": "1.0.0",
  "description": "Advanced Digital Book Reading & Publishing Platform - Backend",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
